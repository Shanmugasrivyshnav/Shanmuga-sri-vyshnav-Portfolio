# PostgreSQL connection string
# Neon / Supabase / Railway all give you this in their dashboard
DATABASE_URL="postgresql://user:password@host:5432/portfolio_db?schema=public"

# Server
PORT=5000
NODE_ENV=development

# CORS - your deployed Vercel frontend URL (no trailing slash)
FRONTEND_URL="https://shanmuga-sri-vyshnav-portfolio.vercel.app"

# Auth
JWT_SECRET="replace-with-a-long-random-string"
JWT_EXPIRES_IN="7d"

# Email (Resend - https://resend.com, free tier: 100 emails/day)
RESEND_API_KEY="re_xxxxxxxxxxxx"
CONTACT_NOTIFICATION_EMAIL="shanmukhasri00@gmail.com"
